# Copy to .env and fill in your values. Do not commit .env.

OPENAI_API_KEY=sk-your-key-here
GITHUB_PAGES_BASE=https://YOURUSERNAME.github.io/aiab

# For email_sender.py (Gmail: use App Password if 2FA is on)
OUTREACH_EMAIL=your-email@gmail.com
OUTREACH_PASSWORD=your-app-password

# Optional: cap emails per run (default 10 for first runs). Set to 0 or leave unset for no limit.
# MAX_EMAILS_PER_RUN=10

# Outreach signature (avoids [Name] / [Your Company] placeholders in generated emails)
OUTREACH_SENDER_NAME=Pranav
OUTREACH_SENDER_COMPANY=SiteRenovate
